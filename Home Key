}

// ===================== ADD HOUSE =====================
function submitOwner() {

    let ownerName = document.getElementById("ownerName").value;
    let area = document.getElementById("area").value;
    let rent = document.getElementById("rent").value;
    let type = document.getElementById("type").value;
    let facing = document.getElementById("facing").value;
    let contact = document.getElementById("contact").value;
    let imageFile = document.getElementById("image").files[0];

    if (!ownerName || !area || !rent || !type || !facing || !contact) {
        alert("Please fill all details");
        return;
    }

    if (!imageFile) {
        alert("Please select image");
        return;
    }

    let reader = new FileReader();

    reader.onload = function (e) {

        let house = {
            ownerName,
            area,
            rent: parseInt(rent),
            type,
            facing,
            contact,
            image: e.target.result
        };

        houses.push(house);
        localStorage.setItem("houses", JSON.stringify(houses));

        alert("House Added Successfully!");
    };

    reader.readAsDataURL(imageFile);
}

// ===================== DISPLAY HOUSE =====================
function displayHouses(searchArea = "") {

    let result = "";

    for (let i = 0; i < houses.length; i++) {

        if (searchArea === "" || houses[i].area.toLowerCase().includes(searchArea)) {

            result +=
                "<div style='border:1px solid #ddd;padding:10px;margin:10px;background:white;border-radius:8px'>" +
                "<img src='" + houses[i].image + "' width='100%' height='150' style='object-fit:cover'><br><br>" +
                "<b>Owner:</b> " + houses[i].ownerName + "<br>" +
                "<b>Area:</b> " + houses[i].area + "<br>" +
                "<b>Rent:</b> ₹" + houses[i].rent + "<br>" +
                "<b>Type:</b> " + houses[i].type + "<br>" +
                "<b>Facing:</b> " + houses[i].facing + "<br>" +
                "<b>Contact:</b> " + houses[i].contact +
                "</div>";
        }
    }

    if (result === "") {
        result = "<p>No houses available</p>";
    }

    let resultDiv = document.getElementById("result");
    if (resultDiv) {
        resultDiv.innerHTML = result;
    }
}

// SEARCH
function searchHouse() {
    let searchArea = document.getElementById("searchArea").value.toLowerCase();
    displayHouses(searchArea);
}

// AUTO LOAD TENANT
if (window.location.pathname.includes("tenant.html")) {
    displayHouses();
}


