// ===================== HOUSE STORAGE =====================
let houses = JSON.parse(localStorage.getItem("houses")) || [];

// ===================== NAVIGATION =====================
function goRole() {
    window.location.href = "role.html";
}

function goRent() {
    window.location.href = "rent.html";
}

function goOwner() {
    window.location.href = "owner.html";
}

function goTenant() {
